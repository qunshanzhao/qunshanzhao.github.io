@misc{enlighten359294,
       booktitle = {CUPUM 2025 The 19th International Conference on Computational Urban Planning and Urban Management},
            year = {2025},
           title = {High-Resolution Mapping of Building Material Stocks and Lifecycle Embodied Carbon Emissions in China},
           month = {June},
          author = {Shao, Zhenfeng and Zhao, Qunshan and Cai, Bowen and Zheng, Xiaoyu and Cheng, Qimin and Park, Jooyoung and Bumsuk, Seok},
        keywords = {Remote sensing, material stocks, embodied carbon emissions, mapping, China.},
        abstract = {Spatial patterns of material stocks in buildings are essential for understanding resource utilization, guiding spatial planning, and informing environmental management. In this study, we propose a volume-based framework for mapping material stocks and lifecycle embodied carbon emissions in buildings at a 10m resolution, applied  to  the entire Beijing-Tianjin-Hebei urban agglomeration(BTH-UA) in China. By integrating multi-source remote sensing data, GIS products, crowdsourced data,   and   material   intensity   databases   for   ten   major   materials,   we   provide   a   comprehensive assessment of both material stocks and  embodied  carbon emissions. The results indicate that the BTH-UA harbors a total material stock of 19,600Mt, with corresponding lifecycle embodied carbon emissions reaching 3,946MtCO e. This integrated mapping offers valuable insights for resource management, spatial planning, and climate mitigation strategies.},
             url = {https://osf.io/5hn43}
